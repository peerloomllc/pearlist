# scripts/.env.example — copy to scripts/.env and fill in.
# scripts/.env is gitignored. NEVER commit real secrets.
#
# NOTE (reuse from PearGuard): most of these values are PeerLoom-account-wide and
# are IDENTICAL to pearguard/scripts/.env. You can copy that file as a starting
# point and only change the two APP-SPECIFIC blocks called out below
# (Android upload keystore + ASC_APP_ID). Tim can run a test release to confirm.

# ==========================================================================
# APP-SPECIFIC — must be unique to PearList (do NOT copy from PearGuard)
# ==========================================================================

# --- Android upload keystore (PearList's own; see scripts note) -------------
# Generate a dedicated PearList keystore (do not reuse PearGuard's). Back it up
# offline — losing it blocks all future Play updates for com.pearlist.
KEYSTORE_FILE=$HOME/pearlist-upload.jks
KEYSTORE_PASSWORD=
KEY_ALIAS=pearlist
KEY_PASSWORD=

# --- App Store numeric app ID (PearList's own record) -----------------------
# Created when the com.pearlist App Store Connect record exists.
# Find it with: asc apps list
ASC_APP_ID=

# ==========================================================================
# SHARED — same values as pearguard/scripts/.env (PeerLoom-account-wide)
# ==========================================================================

# --- Zapstore / Nostr signing identity (shared PeerLoom nsec) ---------------
SIGN_WITH=

# --- GitHub (shared; falls back to `gh auth token` if unset) ----------------
GITHUB_TOKEN=
# GITHUB_REMOTE=github

# --- App Store Connect API key (shared PeerLoom-CI key) ---------------------
# Same key ID / issuer / .p8 / team as PearGuard.
ASC_KEY_ID=
ASC_ISSUER_ID=
ASC_PRIVATE_KEY_PATH=$HOME/.appstoreconnect/AuthKey_<KEY_ID>.p8
ASC_TEAM_ID=G79ALD29NA

# --- Google Play (shared service account or gcloud ADC) ---------------------
# Either point at the shared service-account JSON...
# PLAY_SERVICE_ACCOUNT_JSON=$HOME/.config/peerloom/play-service-account.json
# ...or use gcloud application-default creds + a quota project:
# PLAY_QUOTA_PROJECT=
PLAY_TRACK=internal

# --- Build hosts (shared) ---------------------------------------------------
# MAC_MINI_HOST=Tims-Mac-mini.local
